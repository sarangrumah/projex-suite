# ─── ProjeX Suite Environment Variables ────────────────────
# Copy to .env and fill in real values before running

# App
ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_DB=projex
POSTGRES_USER=projex
POSTGRES_PASSWORD=projex_secret
DATABASE_URL=postgresql+asyncpg://projex:projex_secret@postgres:5432/projex
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (use HS256 for dev, RS256 with key pair for production)
JWT_PRIVATE_KEY=projex-dev-jwt-secret-change-in-production
JWT_PUBLIC_KEY=projex-dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PII Encryption (generate 32-byte key for production)
ENCRYPTION_KEY=change-me-32-byte-key-for-aes256

# Meilisearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=change-me-meili-key

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=projex-files
MINIO_SECURE=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Vault
VAULT_TOKEN=projex-dev-token

# Grafana
GRAFANA_PASSWORD=admin

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ERA AI (Ollama default, set ANTHROPIC_API_KEY for Claude)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=smollm2:135m
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Microservice URLs (Docker internal)
ERA_AI_URL=http://era-ai-api:8100
ERABUDGET_URL=http://erabudget-api:8200
APPCATALOG_URL=http://appcatalog-api:8300
COLLAB_URL=http://collab-server:8400
WAHUB_URL=http://wahub-gateway:8500
